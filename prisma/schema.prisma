// This schema is optional scaffolding — it's only used if you follow the
// Prisma path documented in lib/db.ts. If you pick a different database
// or ORM, delete this file (and the prisma/ folder) entirely; nothing
// else in the app references it directly.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Executive {
  id         String   @id @default(cuid())
  name       String
  role       String // "CEO Agent", "CFO Agent", ...
  trait      String
  bio        String
  focusAreas String[] // Postgres text[]; adjust if your DB doesn't support arrays
  createdAt  DateTime @default(now())

  votes Vote[]
}

model Meeting {
  id           String    @id @default(cuid())
  startupName  String
  oneLiner     String
  industry     String
  stage        String
  pitch        String
  status       String    @default("scheduled") // scheduled | in-progress | completed
  createdAt    DateTime  @default(now())
  completedAt  DateTime?

  transcript Message[]
  votes      Vote[]
  report     Report?
}

model Message {
  id          String   @id @default(cuid())
  meeting     Meeting  @relation(fields: [meetingId], references: [id])
  meetingId   String
  speakerId   String // "founder" or an Executive.id
  speakerName String
  role        String
  message     String
  createdAt   DateTime @default(now())
}

model Vote {
  id          String    @id @default(cuid())
  meeting     Meeting   @relation(fields: [meetingId], references: [id])
  meetingId   String
  executive   Executive @relation(fields: [executiveId], references: [id])
  executiveId String
  vote        String // yes | no | conditional

  @@unique([meetingId, executiveId])
}

model Report {
  id                String   @id @default(cuid())
  meeting           Meeting  @relation(fields: [meetingId], references: [id])
  meetingId         String   @unique
  investmentScore   Int
  verdict           String // "Strong buy" | "Conditional" | "Pass"
  executiveSummary  String
  swot              Json // [{ title, items[] }]
  dimensions        Json // [{ dimension, score }]
  risks             Json // [{ risk, likelihood, impact }]
  financials        Json // [{ label, value }]
  generatedAt       DateTime @default(now())
}
