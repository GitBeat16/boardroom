# React 19 is still new enough that several transitive dependencies
# (react-remove-scroll via @radix-ui/react-dialog and vaul, older
# framer-motion patch versions, etc.) declare peerDependencies capped at
# React 18. They all work correctly at runtime with React 19 — only the
# declared peer *range* is stale. Rather than chase each one individually
# every time npm adds a new transitive package, resolve peers the way npm
# did by default before v7.
legacy-peer-deps=true
