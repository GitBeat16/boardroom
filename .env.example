# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# Powers every AI executive persona (lib/ai/client.ts, lib/ai/board-orchestrator.ts).
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Your database connection string. Shape depends on what you wire up in
# lib/db.ts — e.g. a Postgres URL for Prisma/Drizzle, or a different
# format entirely if you use something else.
DATABASE_URL=

# Optional — only needed if you wire up deck/file uploads in
# app/api/pitches/route.ts via an object store (e.g. Vercel Blob).
BLOB_READ_WRITE_TOKEN=
